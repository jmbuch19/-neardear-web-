  requestId           String
  providerProfileId   String
  status              String    @default("SENT")
  sentAt              DateTime  @default(now())
  seenAt              DateTime?
  respondedAt         DateTime?
  declineReason       String?
  expiresAt           DateTime
  createdAt           DateTime  @default(now())

  request             Request   @relation(fields: [requestId], references: [id])

  @@index([requestId])
  @@index([providerProfileId])
  @@index([status])
  @@index([expiresAt])
  @@map("request_notifications")
}

// ─── BANK ACCOUNTS ────────────────────────────────────

model BankAccount {
  id                    String    @id @default(cuid())
  providerProfileId     String    @unique

  accountHolderName     String
  bankName              String
  accountNumber         String
  accountNumberLast4    String
  ifscCode              String
  accountType           String    @default("SAVINGS")

  upiId                 String?

  isVerified            Boolean   @default(false)
  verifiedAt            DateTime?
  verifiedBy            String?

  isPrimary             Boolean   @default(true)
  isActive              Boolean   @default(true)

  addedAt               DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  providerProfile       ProviderProfile @relation(fields: [providerProfileId], references: [id])
  withdrawals           Withdrawal[]

  @@map("bank_accounts")
}

// ─── CANCELLATION RECORDS ─────────────────────────────

model CancellationRecord {
  id                    String             @id @default(cuid())
  sessionId             String             @unique
  paymentId             String?            @unique

  cancelledBy           CancelledBy
  cancelReason          String?
  cancelReasonCategory  String?

  sessionScheduledAt    DateTime
  cancelledAt           DateTime           @default(now())
  hoursBeforeSession    Float
  window                CancellationWindow

  // Amounts in rupees
  originalAmount        Int
  refundAmount          Int
  companionComp         Int
  platformRetained      Int

  refundStatus          String             @default("PENDING")
  razorpayRefundId      String?
  refundProcessedAt     DateTime?

  compStatus            String             @default("PENDING")
  compPaidAt            DateTime?

  adminOverride         Boolean            @default(false)
  adminNote             String?
  adminId               String?

  createdAt             DateTime           @default(now())

  payment               Payment?           @relation(fields: [paymentId], references: [id])

  @@index([sessionId])
  @@index([cancelledBy])
  @@index([window])
  @@map("cancellation_records")
}

// ─── DISPUTES ─────────────────────────────────────────

model Dispute {
  id                    String          @id @default(cuid())
  sessionId             String          @unique
  paymentId             String?         @unique
  raisedById            String
  raisedAgainstId       String?

  raisedBy              DisputeRaisedBy
  status                DisputeStatus   @default(OPEN)
  severity              String          @default("MEDIUM")

  description           String
  evidenceUrls          String[]

  amountHeld            Int?
  heldAt                DateTime?

  resolution            String?
  resolvedBy            String?
  resolvedAt            DateTime?

  refundAmount          Int?
  companionPenalty      Int?
  platformAbsorbed      Int?

  adminNotes            String?
  escalatedAt           DateTime?
  escalatedTo           String?

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  payment               Payment?        @relation(fields: [paymentId], references: [id])

  @@index([status])
  @@index([severity])
  @@index([raisedById])
  @@index([createdAt])
  @@map("disputes")
}

// ─── PLATFORM REVENUE ─────────────────────────────────

model PlatformRevenue {
  id                    String    @id @default(cuid())
  sessionId             String?
  paymentId             String?
  sourceType            String
  // SESSION_FEE / CANCELLATION_FEE / LATE_CANCEL_FEE / ADJUSTMENT
  amount                Int
  description           String?
  createdAt             DateTime  @default(now())

  @@index([sourceType])
  @@index([createdAt])
  @@map("platform_revenue")
}

// ─── FINANCIAL AUDIT LOG ──────────────────────────────

model FinancialAuditLog {
  id                    String    @id @default(cuid())
  entityType            String
  // PAYMENT / EARNING / WITHDRAWAL / REFUND / DISPUTE / CANCELLATION
  entityId              String
  action                String
  // CREATED / UPDATED / STATUS_CHANGED / HELD / RELEASED / REFUNDED / PAID
  previousValue         Json?
  newValue              Json?
  actorId               String?
  actorType             String?
  // ADMIN / SYSTEM / WEBHOOK
  note                  String?
  createdAt             DateTime  @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("financial_audit_log")
}

// ─── RATE CONFIGURATION ───────────────────────────────

model CompanionRateConfig {
  id                  String    @id @default(cuid())
  providerProfileId   String

  companionSharePct   Float
  platformSharePct    Float

  reason              String
  effectiveFrom       DateTime  @default(now())
  effectiveTo         DateTime?

  setBy               String
  notifiedAt          DateTime?
  notificationNote    String?

  previousRate        Float?
  isActive            Boolean   @default(true)

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  providerProfile     ProviderProfile @relation(fields: [providerProfileId], references: [id])

  @@index([providerProfileId])
  @@index([isActive])
  @@map("companion_rate_configs")
}

model CityRateConfig {
  id                  String    @id @default(cuid())
  cityId              String    @unique

  companionSharePct   Float     @default(80.0)
  platformSharePct    Float     @default(20.0)

  reason              String?
  effectiveFrom       DateTime  @default(now())
  setBy               String

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([cityId])
  @@map("city_rate_configs")
}

model PlatformRateConfig {
  id                  String    @id @default(cuid())

  companionSharePct   Float     @default(80.0)
  platformSharePct    Float     @default(20.0)

  reason              String
  effectiveFrom       DateTime
  announcedAt         DateTime?
  announcedBy         String
  noticeGivenDays     Int       @default(60)

  previousRate        Float?
  isActive            Boolean   @default(true)

  createdAt           DateTime  @default(now())

  @@index([isActive])
  @@index([effectiveFrom])
  @@map("platform_rate_configs")
}

// ─── BONUS SYSTEM ─────────────────────────────────────

model BonusEvent {
  id                  String    @id @default(cuid())

  name                String
  description         String
  amount              Int

  targetType          String
  targetCity          String?
  targetGender        String?
  targetTrustLevel    String?
  targetCompanionId   String?

  status              String    @default("DRAFT")

  scheduledFor        DateTime?
  executedAt          DateTime?
  executedBy          String?

  totalCompanions     Int?
  totalAmount         Int?

  createdBy           String
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  bonusCredits        BonusCredit[]

  @@index([status])
  @@index([scheduledFor])
  @@map("bonus_events")
}

model BonusCredit {
  id                  String    @id @default(cuid())
  bonusEventId        String
  providerProfileId   String

  amount              Int
  reason              String

  status              String    @default("CREDITED")

  creditedAt          DateTime  @default(now())
  paidAt              DateTime?
  withdrawalId        String?

  bonusEvent          BonusEvent      @relation(fields: [bonusEventId], references: [id])
  providerProfile     ProviderProfile @relation(fields: [providerProfileId], references: [id])

  @@index([providerProfileId])
  @@index([bonusEventId])
  @@index([status])
  @@map("bonus_credits")
}

// ─── PERFORMANCE WARNINGS ─────────────────────────────

model PerformanceWarning {
  id                  String    @id @default(cuid())
  providerProfileId   String

  level               String

  reason              String
  triggerType         String

  issuedBy            String
  issuedAt            DateTime  @default(now())

  actionTaken         String?

  previousTrustLevel  String?
  newTrustLevel       String?
  previousRate        Float?
  newRate             Float?

  expiresAt           DateTime?
  resolvedAt          DateTime?
  resolvedBy          String?
  resolutionNote      String?

  notifiedAt          DateTime?
  acknowledgedAt      DateTime?

  createdAt           DateTime  @default(now())

  providerProfile     ProviderProfile @relation(fields: [providerProfileId], references: [id])

  @@index([providerProfileId])
  @@index([level])
  @@index([issuedAt])
  @@map("performance_warnings")
}

// ─── COMPANION CONSENT ────────────────────────────────

model CompanionConsent {
  id                    String    @id @default(cuid())
  providerProfileId     String
  policyVersion         String    @default("1.0")
  agreedAt              DateTime  @default(now())
  ipAddress             String?
  userAgent             String?

  @@index([providerProfileId])
  @@map("companion_consents")
}

// ─── CARE PLANS ───────────────────────────────────────

model CarePlan {
  id                    String        @id @default(cuid())
  userId                String
  elderProfileId        String?
  providerProfileId     String
  serviceCategoryId     String

  // Plan configuration
  frequency             PlanFrequency
  duration              PlanDuration
  billing               PlanBilling

  // Sessions
  totalSessions         Int
  sessionsCompleted     Int           @default(0)
  sessionsRemaining     Int
  preferredDays         String[]
  preferredTime         String?

  // Pricing
  regularPricePerVisit  Int
  discountPercent       Float
  planPricePerVisit     Int
  totalRegularPrice     Int
  totalPlanPrice        Int
  totalSavings          Int

  // Upfront extra discount
  upfrontExtraDiscount  Float         @default(0)

  // Billing
  monthlyAmount         Int?
  nextBillingDate       DateTime?
  lastBilledDate        DateTime?
  billingCycleCount     Int           @default(0)

  // Status
  status                PlanStatus    @default(DRAFT)
  startDate             DateTime?
  endDate               DateTime?
  pausedAt              DateTime?
  pausedUntil           DateTime?
  totalPauseDays        Int           @default(0)

  // Cancellation
  cancelledAt           DateTime?
  cancelReason          String?
  refundAmount          Int?
  companionCompAmount   Int?

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user                  User          @relation(fields: [userId], references: [id])
  elderProfile          ElderProfile? @relation(fields: [elderProfileId], references: [id])
  providerProfile       ProviderProfile @relation(fields: [providerProfileId], references: [id])
  planSessions          PlanSession[]
  planPayments          PlanPayment[]

  @@index([userId])
  @@index([providerProfileId])
  @@index([status])
  @@index([nextBillingDate])
  @@map("care_plans")
}

model PlanSession {
  id                String    @id @default(cuid())
  carePlanId        String
  sessionId         String?   @unique
  scheduledDate     DateTime
  scheduledTime     String
  status            String    @default("SCHEDULED")

  createdAt         DateTime  @default(now())

  carePlan          CarePlan  @relation(fields: [carePlanId], references: [id])

  @@index([carePlanId])
  @@index([scheduledDate])
  @@map("plan_sessions")
}

model PlanPayment {
  id                String    @id @default(cuid())
  carePlanId        String
  cycleNumber       Int
  amount            Int
  status            String    @default("PENDING")
  razorpayOrderId   String?
  razorpayPaymentId String?
  dueDate           DateTime
  paidAt            DateTime?

  createdAt         DateTime  @default(now())

  carePlan          CarePlan  @relation(fields: [carePlanId], references: [id])

  @@index([carePlanId])
  @@index([dueDate])
  @@map("plan_payments")
}

// ─── GDPR / DATA DELETION ─────────────────────────────

model DataDeletionRequest {
  id              String    @id @default(cuid())
  userId          String
  requestType     String
  // ACCOUNT_DELETE / ELDER_DELETE /
  // NOTIFICATION_CLEAR / DATA_EXPORT
  status          String    @default("PENDING")
  // PENDING / PROCESSING / COMPLETED
  requestedAt     DateTime  @default(now())
  processedAt     DateTime?
  scheduledFor    DateTime?
  // 30 days after request for anonymisation
  notes           String?

  @@index([userId])
  @@index([status])
  @@index([scheduledFor])
  @@map("data_deletion_requests")
}
