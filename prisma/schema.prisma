// ─── SOS REQUESTS ────────────────────────────────────

model SosRequest {
  id                  String    @id @default(cuid())
  userId              String?
  phone               String
  area                String
  description         String
  city                String    @default("Ahmedabad")
  status              String    @default("SEARCHING")
